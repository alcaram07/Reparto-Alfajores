@model ClienteViewModel
@{
    ViewData["Title"] = "Nuevo cliente";
}

<div class="page-header">
    <h1><i class="bi bi-person-plus me-2" style="color:var(--color-primary)"></i>Nuevo cliente</h1>
</div>

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card">
            <div class="card-body">
                <form asp-action="Nuevo" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2" style="font-size:0.85rem"></div>

                    <div class="mb-3">
                        <label asp-for="Nombre" class="form-label fw-semibold">Nombre *</label>
                        <input asp-for="Nombre" class="form-control" placeholder="Nombre completo" />
                        <span asp-validation-for="Nombre" class="text-danger" style="font-size:0.8rem"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Telefono" class="form-label fw-semibold">Teléfono</label>
                        <input asp-for="Telefono" class="form-control" placeholder="Ej: 11-1234-5678" />
                        <span asp-validation-for="Telefono" class="text-danger" style="font-size:0.8rem"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Direccion" class="form-label fw-semibold">Dirección</label>
                        <input asp-for="Direccion" class="form-control" placeholder="Dirección de entrega" />
                    </div>

                    <div class="mb-3">
                        <label asp-for="ZonaId" class="form-label fw-semibold">Zona *</label>
                        <select asp-for="ZonaId" asp-items="Model.Zonas" class="form-select">
                            <option value="0">-- Seleccionar zona --</option>
                        </select>
                        <span asp-validation-for="ZonaId" class="text-danger" style="font-size:0.8rem"></span>
                    </div>

                    <div class="mb-4">
                        <div class="form-check">
                            <input asp-for="Activo" class="form-check-input" type="checkbox" />
                            <label asp-for="Activo" class="form-check-label">Cliente activo</label>
                        </div>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check me-1"></i> Guardar
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
