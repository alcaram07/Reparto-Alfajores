@model Cliente
@{
    ViewData["Title"] = Model.Nombre;
    var saldo = (decimal)ViewBag.Saldo;
    var ventas = ViewBag.Ventas as IEnumerable<Venta> ?? new List<Venta>();
    var cobros = ViewBag.Cobros as IEnumerable<Cobro> ?? new List<Cobro>();
    string Fmt(decimal v) => v.ToString("N2", new System.Globalization.CultureInfo("es-AR"));
    string ResumenProductos(IEnumerable<DetalleVenta> detalles) =>
        string.Join(" · ", detalles.Select(d => $"{d.Cantidad}× {d.Producto?.Nombre}"));
}

<div class="page-header d-flex justify-content-between align-items-center">
    <h1><i class="bi bi-person me-2" style="color:var(--color-primary)"></i>@Model.Nombre</h1>
    <div class="d-flex gap-2">
        <a asp-action="Editar" asp-route-id="@Model.Id" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-pencil me-1"></i> Editar
        </a>
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-left me-1"></i> Volver
        </a>
    </div>
</div>

<div class="row g-3">
    <!-- Info cliente -->
    <div class="col-md-4">
        <div class="card mb-3">
            <div class="card-header">Información</div>
            <div class="card-body" style="font-size:0.9rem">
                @if (!string.IsNullOrEmpty(Model.Telefono))
                {
                    <div class="mb-2"><i class="bi bi-telephone me-2 text-muted"></i>@Model.Telefono</div>
                }
                @if (!string.IsNullOrEmpty(Model.Direccion))
                {
                    <div class="mb-2"><i class="bi bi-geo-alt me-2 text-muted"></i>@Model.Direccion</div>
                }
                <div class="mb-2"><i class="bi bi-pin-map me-2 text-muted"></i>@Model.Zona?.Nombre</div>
                <div><i class="bi bi-calendar me-2 text-muted"></i>Alta: @Model.FechaAlta.ToString("dd/MM/yyyy")</div>
            </div>
        </div>

        <!-- Saldo -->
        <div class="card" style="border-color: @(saldo > 0 ? "var(--color-danger)" : "var(--color-success)")">
            <div class="card-body text-center">
                <div style="font-size:0.8rem; color:#888; margin-bottom:4px">Saldo pendiente</div>
                <div style="font-size:2rem; font-weight:700; color:@(saldo > 0 ? "var(--color-danger)" : "var(--color-success)")">
                    $@Fmt(saldo)
                </div>
                @if (saldo > 0)
                {
                    <a asp-controller="Cobros" asp-action="Index" asp-route-clienteId="@Model.Id"
                       class="btn btn-sm btn-primary mt-2">
                        <i class="bi bi-cash-coin me-1"></i> Registrar cobro
                    </a>
                }
                else
                {
                    <div class="mt-1"><span class="badge-ok">Sin deuda</span></div>
                }
            </div>
        </div>
    </div>

    <!-- Historial -->
    <div class="col-md-8">
        <!-- Ventas -->
        <div class="card mb-3">
            <div class="card-header"><i class="bi bi-cart3 me-1"></i> Historial de ventas (@ventas.Count())</div>
            <div class="card-body p-0">
                @if (!ventas.Any())
                {
                    <div class="text-center text-muted py-3" style="font-size:0.85rem">Sin ventas</div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover mb-0" style="font-size:0.85rem">
                            <thead>
                                <tr><th>Fecha</th><th>Productos</th><th>Total</th><th>Estado</th></tr>
                            </thead>
                            <tbody>
                                @foreach (var v in ventas.Take(20))
                                {
                                    <tr>
                                        <td>@v.Fecha.ToString("dd/MM/yy HH:mm")</td>
                                        <td class="text-muted">@ResumenProductos(v.Detalles)</td>
                                        <td><strong>$@Fmt(v.Total)</strong></td>
                                        <td>
                                            @if (v.EstadoCobro == EstadoCobro.Cobrado)
                                            {<span class="badge-ok">Cobrado</span>}
                                            else
                                            {<span class="badge-danger">Cta. Cte.</span>}
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>

        <!-- Cobros -->
        <div class="card">
            <div class="card-header"><i class="bi bi-cash-coin me-1"></i> Historial de cobros (@cobros.Count())</div>
            <div class="card-body p-0">
                @if (!cobros.Any())
                {
                    <div class="text-center text-muted py-3" style="font-size:0.85rem">Sin cobros</div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover mb-0" style="font-size:0.85rem">
                            <thead>
                                <tr><th>Fecha</th><th>Método</th><th>Monto</th><th>Nota</th></tr>
                            </thead>
                            <tbody>
                                @foreach (var c in cobros.Take(20))
                                {
                                    <tr>
                                        <td>@c.Fecha.ToString("dd/MM/yy HH:mm")</td>
                                        <td>@c.MetodoPago</td>
                                        <td><strong class="text-success">$@Fmt(c.Monto)</strong></td>
                                        <td class="text-muted">@c.Nota</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
