@{
    ViewData["Title"] = "Cobros";
    string Fmt(decimal v) => v.ToString("N2", new System.Globalization.CultureInfo("es-AR"));
    var deudores = ViewBag.Deudores as IEnumerable<DeudorViewModel> ?? new List<DeudorViewModel>();
    var cobrosHoy = ViewBag.CobrosHoy as IEnumerable<Cobro> ?? new List<Cobro>();
    var vmCobro = ViewBag.VmCobro as CobroViewModel ?? new CobroViewModel();
    string BadgeDias(int dias) => dias < 7 ? "badge-ok" : dias <= 20 ? "badge-warn" : "badge-danger";
}

<div class="page-header">
    <h1><i class="bi bi-cash-coin me-2" style="color:var(--color-primary)"></i>Cobros y deudores</h1>
</div>

<!-- Métricas -->
<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="metric-card">
            <i class="bi bi-exclamation-circle metric-icon" style="color:var(--color-danger)"></i>
            <div class="metric-label">Total por cobrar</div>
            <div class="metric-value" style="color:var(--color-danger)">$@Fmt((decimal)ViewBag.TotalPorCobrar)</div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="metric-card">
            <i class="bi bi-check-circle metric-icon" style="color:var(--color-success)"></i>
            <div class="metric-label">Cobrado hoy</div>
            <div class="metric-value" style="color:var(--color-success)">$@Fmt((decimal)ViewBag.TotalCobradoHoy)</div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="metric-card">
            <i class="bi bi-clock metric-icon"></i>
            <div class="metric-label">Deuda más antigua</div>
            @if (ViewBag.DeudorMasAntiguo is DeudorViewModel dma)
            {
                <div class="metric-value" style="font-size:1rem">@dma.Nombre</div>
                <small class="@BadgeDias(dma.DiasDeuda)">@dma.DiasDeuda días</small>
            }
            else
            {
                <div class="metric-value" style="font-size:1rem; color:#888">—</div>
            }
        </div>
    </div>
</div>

<div class="row g-3">
    <!-- Tabla deudores -->
    <div class="col-md-7">
        <div class="card mb-3">
            <div class="card-header"><i class="bi bi-people me-1"></i> Deudores</div>
            <div class="card-body p-0">
                @if (!deudores.Any())
                {
                    <div class="text-center text-muted py-4">
                        <i class="bi bi-check-circle" style="font-size:2rem;opacity:0.2;color:var(--color-success)"></i>
                        <p class="mt-2">Sin deudores</p>
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover mb-0" style="font-size:0.87rem">
                            <thead>
                                <tr>
                                    <th>Cliente</th>
                                    <th>Saldo</th>
                                    <th>Días sin pagar</th>
                                    <th>Último pago</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var d in deudores)
                                {
                                    <tr>
                                        <td>
                                            <div class="fw-semibold">@d.Nombre</div>
                                            <small class="text-muted">@d.Zona</small>
                                        </td>
                                        <td class="fw-bold" style="color:var(--color-danger)">$@Fmt(d.Saldo)</td>
                                        <td><span class="@BadgeDias(d.DiasDeuda)">@d.DiasDeuda días</span></td>
                                        <td class="text-muted">
                                            @(d.UltimoPago.HasValue ? d.UltimoPago.Value.ToString("dd/MM/yy") : "—")
                                        </td>
                                        <td>
                                            <a asp-action="Index" asp-route-clienteId="@d.ClienteId"
                                               class="btn btn-sm btn-primary py-0 px-2">
                                                Cobrar
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>

        <!-- Cobros de hoy -->
        <div class="card">
            <div class="card-header"><i class="bi bi-clock-history me-1"></i> Cobros de hoy</div>
            <div class="card-body p-0">
                @if (!cobrosHoy.Any())
                {
                    <div class="text-center text-muted py-3" style="font-size:0.85rem">Sin cobros hoy</div>
                }
                else
                {
                    <ul class="list-group list-group-flush">
                        @foreach (var c in cobrosHoy)
                        {
                            <li class="list-group-item d-flex justify-content-between align-items-center" style="font-size:0.87rem">
                                <div>
                                    <span class="fw-semibold">@c.Cliente?.Nombre</span>
                                    <span class="text-muted ms-2">· @c.MetodoPago</span>
                                </div>
                                <div class="d-flex align-items-center gap-2">
                                    <small class="text-muted">@c.Fecha.ToString("HH:mm")</small>
                                    <span class="fw-bold" style="color:var(--color-success)">$@Fmt(c.Monto)</span>
                                </div>
                            </li>
                        }
                    </ul>
                }
            </div>
        </div>
    </div>

    <!-- Formulario cobro -->
    <div class="col-md-5">
        <div class="card sticky-top" style="top:20px">
            <div class="card-header"><i class="bi bi-cash-coin me-1"></i> Registrar cobro</div>
            <div class="card-body">
                <form asp-action="Registrar" method="post">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Cliente *</label>
                        <select name="ClienteId" class="form-select" required>
                            <option value="0">-- Seleccioná un cliente --</option>
                            @foreach (var item in vmCobro.Clientes)
                            {
                                if (item.Value == vmCobro.ClienteId.ToString())
                                {
                                    <option value="@item.Value" selected>@item.Text</option>
                                }
                                else
                                {
                                    <option value="@item.Value">@item.Text</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Monto *</label>
                        <div class="input-group">
                            <span class="input-group-text">$</span>
                            <input name="Monto" type="number" step="0.01" min="0.01" class="form-control" placeholder="0.00" required />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Método de pago</label>
                        <div>
                            @foreach (MetodoPago mp in Enum.GetValues(typeof(MetodoPago)))
                            {
                                if (mp == MetodoPago.CuentaCorriente) continue;
                                <div class="form-check form-check-inline">
                                    <input class="form-check-input" type="radio" name="MetodoPago"
                                           id="cmp_@mp" value="@((int)mp)"
                                           @(mp == MetodoPago.Efectivo ? "checked" : "") />
                                    <label class="form-check-label" for="cmp_@mp">@mp</label>
                                </div>
                            }
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Nota (opcional)</label>
                        <input name="Nota" class="form-control" placeholder="Observaciones..." />
                    </div>
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="bi bi-check-circle me-1"></i> Confirmar cobro
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>
