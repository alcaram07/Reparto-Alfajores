@model VentaViewModel
@{
    ViewData["Title"] = "Nueva venta";
}

<div class="page-header">
    <h1><i class="bi bi-plus-circle me-2" style="color:var(--color-primary)"></i>Nueva venta</h1>
</div>

<div class="row g-3">
    <div class="col-lg-7">
        <div class="card">
            <div class="card-body">
                <form asp-action="Nuevo" method="post" id="ventaForm">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 mb-3" style="font-size:0.85rem"></div>

                    <!-- Paso 1: Cliente -->
                    <div class="mb-4">
                        <h6 class="fw-bold mb-2" style="color:var(--color-primary)">1. Seleccionar cliente</h6>
                        <select asp-for="ClienteId" asp-items="Model.Clientes" class="form-select" id="clienteSelect">
                            <option value="0">-- Seleccioná un cliente --</option>
                        </select>
                        <span asp-validation-for="ClienteId" class="text-danger" style="font-size:0.8rem"></span>
                    </div>

                    <!-- Paso 2: Productos -->
                    <div class="mb-4">
                        <h6 class="fw-bold mb-2" style="color:var(--color-primary)">2. Agregar productos</h6>
                        <div class="d-flex gap-2 mb-2">
                            <select id="productoSelect" class="form-select">
                                <option value="">-- Producto --</option>
                                @foreach (var p in Model.Productos)
                                {
                                    <option value="@p.Value">@p.Text</option>
                                }
                            </select>
                            <input type="number" id="cantidadInput" class="form-control" style="max-width:90px" min="1" value="1" />
                            <button type="button" class="btn btn-outline-primary" onclick="agregarProducto()">
                                <i class="bi bi-plus"></i>
                            </button>
                        </div>
                        <div id="detallesContainer"></div>
                        <div id="detallesHidden"></div>
                        @if (ViewData.ModelState.ContainsKey("Detalles") && ViewData.ModelState["Detalles"]!.Errors.Any())
                        {
                            <div class="text-danger" style="font-size:0.8rem">Agregue al menos un producto</div>
                        }
                    </div>

                    <!-- Paso 3: Método de pago -->
                    <div class="mb-4">
                        <h6 class="fw-bold mb-2" style="color:var(--color-primary)">3. Forma de cobro</h6>
                        <div class="d-flex gap-2 flex-wrap">
                            @foreach (MetodoPago mp in Enum.GetValues(typeof(MetodoPago)))
                            {
                                <div class="form-check form-check-inline">
                                    <input class="form-check-input" type="radio" name="MetodoPago"
                                           id="mp_@mp" value="@((int)mp)"
                                           @(mp == MetodoPago.Efectivo ? "checked" : "") />
                                    <label class="form-check-label" for="mp_@mp">@mp</label>
                                </div>
                            }
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label">Nota (opcional)</label>
                        <input asp-for="Nota" class="form-control" placeholder="Observaciones..." />
                    </div>

                    <!-- Total -->
                    <div class="d-flex justify-content-between align-items-center p-3 mb-3 rounded" style="background:var(--color-primary-light)">
                        <span class="fw-bold" style="color:var(--color-primary-dark)">Total</span>
                        <span class="fw-bold fs-4" style="color:var(--color-primary)" id="totalDisplay">$0,00</span>
                    </div>

                    <button type="submit" class="btn btn-primary w-100 btn-lg">
                        <i class="bi bi-check-circle me-1"></i> Confirmar venta
                    </button>
                </form>
            </div>
        </div>
    </div>

    <div class="col-lg-5">
        <div class="card">
            <div class="card-header">Resumen de ítems</div>
            <div class="card-body p-0" id="resumenContainer">
                <div class="text-center text-muted py-4" id="resumenVacio">
                    <i class="bi bi-cart" style="font-size:2rem;opacity:0.2"></i>
                    <p class="mt-2 mb-0" style="font-size:0.85rem">Sin productos agregados</p>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
const productPrices = @Html.Raw(Model.ProductosPreciosJson);
const productNames = {};
@foreach (var p in Model.Productos)
{
    @:productNames[@p.Value] = '@p.Text.Replace("'", "\\'")';
}

let items = [];

function agregarProducto() {
    const sel = document.getElementById('productoSelect');
    const productId = parseInt(sel.value);
    if (!productId) return;
    const qty = parseInt(document.getElementById('cantidadInput').value) || 1;
    const precio = productPrices[productId] || 0;
    const nombre = productNames[productId] || sel.options[sel.selectedIndex].text;

    const existing = items.findIndex(i => i.productId === productId);
    if (existing >= 0) {
        items[existing].qty += qty;
    } else {
        items.push({ productId, qty, precio, nombre });
    }
    renderItems();
}

function eliminarItem(idx) {
    items.splice(idx, 1);
    renderItems();
}

function renderItems() {
    const container = document.getElementById('detallesContainer');
    const hidden = document.getElementById('detallesHidden');
    const resumen = document.getElementById('resumenContainer');
    const vacio = document.getElementById('resumenVacio');

    hidden.innerHTML = '';
    items.forEach((item, i) => {
        hidden.innerHTML += `<input type="hidden" name="Detalles[${i}].ProductoId" value="${item.productId}">`;
        hidden.innerHTML += `<input type="hidden" name="Detalles[${i}].Cantidad" value="${item.qty}">`;
    });

    if (items.length === 0) {
        if (vacio) vacio.style.display = '';
        return;
    }
    if (vacio) vacio.style.display = 'none';

    let tableHtml = '<table class="table table-hover mb-0" style="font-size:0.87rem"><tbody>';
    items.forEach((item, i) => {
        const subtotal = item.qty * item.precio;
        tableHtml += `<tr>
            <td>${item.nombre.split('(')[0].trim()}</td>
            <td class="text-center">${item.qty}</td>
            <td class="text-end fw-semibold">$${subtotal.toLocaleString('es-AR', {minimumFractionDigits:2})}</td>
            <td><button type="button" class="btn btn-sm btn-outline-danger py-0 px-1" onclick="eliminarItem(${i})"><i class="bi bi-x"></i></button></td>
        </tr>`;
    });
    tableHtml += '</tbody></table>';
    resumen.innerHTML = tableHtml;

    updateTotal();
}

function updateTotal() {
    const total = items.reduce((s, i) => s + i.qty * i.precio, 0);
    document.getElementById('totalDisplay').textContent = '$' + total.toLocaleString('es-AR', {minimumFractionDigits:2});
}
</script>
}
