@model IEnumerable<Venta>
@{
    ViewData["Title"] = "Ventas";
    string Fmt(decimal v) => v.ToString("N2", new System.Globalization.CultureInfo("es-AR"));
    string ResumenProductos(IEnumerable<DetalleVenta> detalles) =>
        string.Join(" · ", detalles.Select(d => $"{d.Cantidad}× {d.Producto?.Nombre}"));
    var zonas = ViewBag.Zonas as IEnumerable<Zona> ?? new List<Zona>();
    var ventasList = Model.ToList();
}

<div class="page-header d-flex justify-content-between align-items-center">
    <h1><i class="bi bi-cart3 me-2" style="color:var(--color-primary)"></i>Ventas</h1>
    <a asp-action="Nuevo" class="btn btn-primary"><i class="bi bi-plus-circle me-1"></i> Nueva venta</a>
</div>

<!-- Filtros -->
<div class="card mb-3">
    <div class="card-body py-2">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-md-3">
                <input type="date" name="fecha" class="form-control form-control-sm" value="@ViewBag.Fecha" />
            </div>
            <div class="col-md-3">
                <input type="text" name="busqueda" class="form-control form-control-sm" placeholder="Buscar cliente..." value="@ViewBag.Busqueda" />
            </div>
            <div class="col-md-2">
                <select name="estado" class="form-select form-select-sm">
                    <option value="">Todos</option>
                    <option value="0" selected="@(ViewBag.Estado?.ToString() == "Cobrado")">Cobrado</option>
                    <option value="1" selected="@(ViewBag.Estado?.ToString() == "CuentaCorriente")">Cta. Cte.</option>
                </select>
            </div>
            <div class="col-md-2">
                <select name="zonaId" class="form-select form-select-sm">
                    <option value="">Todas las zonas</option>
                    @foreach (var z in zonas)
                    {
                        <option value="@z.Id" selected="@(ViewBag.ZonaId?.ToString() == z.Id.ToString())">@z.Nombre</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-sm btn-primary w-100">Filtrar</button>
            </div>
        </form>
    </div>
</div>

<div class="card">
    <div class="card-body p-0">
        @if (!ventasList.Any())
        {
            <div class="text-center text-muted py-5">
                <i class="bi bi-cart" style="font-size:2.5rem;opacity:0.2"></i>
                <p class="mt-2">Sin ventas para el período seleccionado</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover mb-0" style="font-size:0.88rem">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Cliente</th>
                            <th>Zona</th>
                            <th>Productos</th>
                            <th>Total</th>
                            <th>Estado</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var v in ventasList)
                        {
                            <tr>
                                <td class="text-muted">@v.Id</td>
                                <td>
                                    <div class="fw-semibold">@v.Cliente?.Nombre</div>
                                    <small class="text-muted">@v.Fecha.ToString("HH:mm")</small>
                                </td>
                                <td><small class="text-muted">@v.Cliente?.Zona?.Nombre</small></td>
                                <td class="text-muted" style="max-width:180px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap">
                                    @ResumenProductos(v.Detalles)
                                </td>
                                <td><strong>$@Fmt(v.Total)</strong></td>
                                <td>
                                    @if (v.EstadoCobro == EstadoCobro.Cobrado)
                                    {<span class="badge-ok">Cobrado</span>}
                                    else
                                    {<span class="badge-danger">Cta. Cte.</span>}
                                </td>
                                <td>
                                    <a asp-action="Detalle" asp-route-id="@v.Id" class="btn btn-sm btn-outline-secondary">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    <form asp-action="Eliminar" asp-route-id="@v.Id" method="post" class="d-inline"
                                          onsubmit="return confirm('¿Eliminar esta venta?')">
                                        <button type="submit" class="btn btn-sm btn-outline-danger">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                    <tfoot class="table-light">
                        <tr>
                            <td colspan="4" class="text-end fw-semibold">Total del día:</td>
                            <td class="fw-bold" style="color:var(--color-primary)">$@Fmt(ventasList.Sum(v => v.Total))</td>
                            <td colspan="2"></td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        }
    </div>
</div>
