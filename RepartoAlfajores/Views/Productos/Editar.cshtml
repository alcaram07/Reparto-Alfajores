@model ProductoViewModel
@{
    ViewData["Title"] = "Editar producto";
}

<div class="page-header">
    <h1><i class="bi bi-pencil me-2" style="color:var(--color-primary)"></i>Editar producto</h1>
</div>

<div class="row justify-content-center">
    <div class="col-md-5">
        <div class="card">
            <div class="card-body">
                <form asp-action="Editar" method="post">
                    @Html.AntiForgeryToken()
                    <input asp-for="Id" type="hidden" />
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2" style="font-size:0.85rem"></div>

                    <div class="mb-3">
                        <label asp-for="Nombre" class="form-label fw-semibold">Nombre *</label>
                        <input asp-for="Nombre" class="form-control" />
                        <span asp-validation-for="Nombre" class="text-danger" style="font-size:0.8rem"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="CategoriaId" class="form-label fw-semibold">Categoría *</label>
                        <select asp-for="CategoriaId" asp-items="Model.Categorias" class="form-select">
                            <option value="0">-- Categoría --</option>
                        </select>
                        <span asp-validation-for="CategoriaId" class="text-danger" style="font-size:0.8rem"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="PrecioUnitario" class="form-label fw-semibold">Precio *</label>
                        <div class="input-group">
                            <span class="input-group-text">$</span>
                            <input asp-for="PrecioUnitario" type="number" step="0.01" min="0.01" class="form-control" />
                        </div>
                        <span asp-validation-for="PrecioUnitario" class="text-danger" style="font-size:0.8rem"></span>
                    </div>

                    <div class="mb-4">
                        <div class="form-check">
                            <input asp-for="Activo" class="form-check-input" type="checkbox" />
                            <label asp-for="Activo" class="form-check-label">Activo</label>
                        </div>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check me-1"></i> Guardar
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
