@model IEnumerable<Producto>
@{
    ViewData["Title"] = "Productos";
    string Fmt(decimal v) => v.ToString("N2", new System.Globalization.CultureInfo("es-AR"));
    var categorias = ViewBag.Categorias as IEnumerable<CategoriaProducto> ?? new List<CategoriaProducto>();
    var vmNuevo = ViewBag.VmNuevo as ProductoViewModel ?? new ProductoViewModel();
    string CatEmoji(string nombre) => nombre?.ToLower() switch {
        "alfajores" => "🍫",
        "tortas" => "🎂",
        "masas" => "🥐",
        _ => "🍬"
    };
}

<div class="page-header d-flex justify-content-between align-items-center">
    <h1><i class="bi bi-box-seam me-2" style="color:var(--color-primary)"></i>Productos</h1>
</div>

<!-- Filtros -->
<div class="mb-3">
    <form method="get" class="d-flex gap-2 flex-wrap">
        <input type="text" name="busqueda" class="form-control form-control-sm" style="max-width:220px" placeholder="Buscar..." value="@ViewBag.Busqueda" />
        <select name="activo" class="form-select form-select-sm" style="max-width:150px">
            <option value="">Todos</option>
            <option value="true" selected="@(ViewBag.Activo?.ToString() == "True")">Activos</option>
            <option value="false" selected="@(ViewBag.Activo?.ToString() == "False")">Inactivos</option>
        </select>
        <button type="submit" class="btn btn-sm btn-primary">Filtrar</button>
    </form>
</div>

<!-- Tabs de categoría -->
<ul class="nav nav-tabs mb-3">
    <li class="nav-item">
        <a class="nav-link @(ViewBag.CategoriaId == null ? "active" : "")"
           href="@Url.Action("Index", new { busqueda = ViewBag.Busqueda, activo = ViewBag.Activo })">Todas</a>
    </li>
    @foreach (var cat in categorias)
    {
        <li class="nav-item">
            <a class="nav-link @(ViewBag.CategoriaId?.ToString() == cat.Id.ToString() ? "active" : "")"
               href="@Url.Action("Index", new { categoriaId = cat.Id, busqueda = ViewBag.Busqueda, activo = ViewBag.Activo })">
                @CatEmoji(cat.Nombre) @cat.Nombre
            </a>
        </li>
    }
</ul>

<div class="row g-3">
    <!-- Cards de productos -->
    <div class="col-md-8">
        @if (!Model.Any())
        {
            <div class="text-center text-muted py-5">
                <i class="bi bi-box-seam" style="font-size:2.5rem;opacity:0.2"></i>
                <p class="mt-2">No se encontraron productos</p>
            </div>
        }
        else
        {
            <div class="row g-2">
                @foreach (var p in Model)
                {
                    <div class="col-sm-6 col-lg-4">
                        <div class="card h-100 @(!p.Activo ? "opacity-50" : "")">
                            <div class="card-body">
                                <div class="d-flex justify-content-between align-items-start">
                                    <div style="font-size:1.8rem">@CatEmoji(p.Categoria?.Nombre ?? "")</div>
                                    @if (p.Activo)
                                    {<span class="badge-ok">Activo</span>}
                                    else
                                    {<span class="badge-danger">Inactivo</span>}
                                </div>
                                <div class="fw-semibold mt-2">@p.Nombre</div>
                                <small class="text-muted">@p.Categoria?.Nombre</small>
                                <div class="fw-bold mt-1" style="color:var(--color-primary); font-size:1.1rem">$@Fmt(p.PrecioUnitario)</div>
                                <div class="mt-2 d-flex gap-1">
                                    <a asp-action="Editar" asp-route-id="@p.Id" class="btn btn-sm btn-outline-secondary flex-fill">
                                        <i class="bi bi-pencil"></i> Editar
                                    </a>
                                    <form asp-action="ToggleActivo" asp-route-id="@p.Id" method="post">
                                        <button type="submit" class="btn btn-sm @(p.Activo ? "btn-outline-warning" : "btn-outline-success")">
                                            @(p.Activo ? "Desactivar" : "Activar")
                                        </button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>

    <!-- Formulario nuevo producto -->
    <div class="col-md-4">
        <div class="card sticky-top" style="top:20px">
            <div class="card-header"><i class="bi bi-plus-circle me-1"></i> Nuevo producto</div>
            <div class="card-body">
                <form asp-action="Nuevo" method="post">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Nombre *</label>
                        <input name="Nombre" class="form-control form-control-sm" placeholder="Nombre del producto" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Categoría *</label>
                        <select name="CategoriaId" class="form-select form-select-sm" required>
                            <option value="0">-- Categoría --</option>
                            @foreach (var item in vmNuevo.Categorias)
                            {
                                <option value="@item.Value">@item.Text</option>
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Precio *</label>
                        <div class="input-group input-group-sm">
                            <span class="input-group-text">$</span>
                            <input name="PrecioUnitario" type="number" step="0.01" min="0.01" class="form-control" placeholder="0.00" required />
                        </div>
                    </div>
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="bi bi-plus me-1"></i> Agregar
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>
